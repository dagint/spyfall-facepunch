{
  "rules": {
    "rooms": {
      "$roomCode": {
        ".read": "auth != null && (data.child('players').child(auth.uid).exists() || !data.child('host').exists())",
        ".write": "auth != null && (data.child('players').child(auth.uid).exists() || !data.exists())",

        "host": {
          ".write": "auth != null && (!data.exists() || data.val() === auth.uid)"
        },

        "settings": {
          ".write": "auth != null && data.parent().child('host').val() === auth.uid"
        },

        "phase": {
          ".write": "auth != null && data.parent().child('host').val() === auth.uid",
          ".validate": "newData.val() === 'lobby' || newData.val() === 'playing' || newData.val() === 'results'"
        },

        "players": {
          "$uid": {
            ".write": "auth != null && ($uid === auth.uid || data.parent().parent().child('host').val() === auth.uid)"
          }
        },

        "customLocations": {
          ".write": "auth != null && data.parent().child('host').val() === auth.uid"
        },

        "game": {
          ".write": "auth != null && data.parent().child('host').val() === auth.uid",

          "votes": {
            "$uid": {
              ".write": "auth != null && $uid === auth.uid",
              ".validate": "newData.isString() && root.child('rooms').child($roomCode).child('players').child(newData.val()).exists()"
            }
          },

          "spyGuess": {
            ".write": "auth != null && (data.parent().child('spyId').val() === auth.uid || data.parent().child('spyIds').child(auth.uid).val() === true)"
          },

          "events": {
            ".write": "auth != null && root.child('rooms').child($roomCode).child('players').child(auth.uid).exists()",
            "$eventId": {
              ".write": "auth != null && root.child('rooms').child($roomCode).child('players').child(auth.uid).exists()"
            }
          }
        }
      }
    }
  }
}
