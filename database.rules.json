{
  "rules": {
    "rooms": {
      "$roomCode": {
        ".read": "auth != null && (data.child('players').child(auth.uid).exists() || !data.child('host').exists())",
        ".write": "auth != null && (!data.exists() || data.child('host').val() === auth.uid || (auth.token.email_verified === true && !newData.exists() && data.child('hostedByAdmin').val() !== true))",

        "phase": {
          ".validate": "newData.val() === 'lobby' || newData.val() === 'playing' || newData.val() === 'results'"
        },

        "players": {
          "$uid": {
            ".write": "auth != null && ($uid === auth.uid || data.parent().parent().child('host').val() === auth.uid)",
            ".validate": "newData.hasChild('name') && newData.child('name').val().length <= 20"
          }
        },

        "game": {
          "votes": {
            "$uid": {
              ".write": "auth != null && $uid === auth.uid && root.child('rooms').child($roomCode).child('phase').val() === 'playing'",
              ".validate": "newData.isString() && root.child('rooms').child($roomCode).child('players').child(newData.val()).exists()"
            }
          },

          "spyGuess": {
            ".write": "auth != null && root.child('rooms').child($roomCode).child('phase').val() === 'playing' && (root.child('roomSecrets').child($roomCode).child('spyId').val() === auth.uid || root.child('roomSecrets').child($roomCode).child('spyIds').child(auth.uid).val() === true)"
          },

          "events": {
            "$eventId": {
              ".write": "auth != null && root.child('rooms').child($roomCode).child('players').child(auth.uid).exists()",
              ".validate": "newData.hasChildren(['type', 'ts']) && (newData.child('type').val() === 'vote' || newData.child('type').val() === 'spy_guess' || newData.child('type').val() === 'majority' || newData.child('type').val() === 'timeout')"
            }
          }
        }
      },

      ".read": "auth != null && auth.token.email != null && auth.token.email_verified === true"
    },

    "roomSecrets": {
      "$roomCode": {
        ".read": "auth != null && root.child('rooms').child($roomCode).child('host').val() === auth.uid",
        ".write": "auth != null && (root.child('rooms').child($roomCode).child('host').val() === auth.uid || (auth.token.email_verified === true && !newData.exists()))"
      }
    },

    "playerRoles": {
      "$roomCode": {
        ".write": "auth != null && (root.child('rooms').child($roomCode).child('host').val() === auth.uid || (auth.token.email_verified === true && !newData.exists()))",
        "$uid": {
          ".read": "auth != null && $uid === auth.uid",
          ".write": "auth != null && (root.child('rooms').child($roomCode).child('host').val() === auth.uid || (auth.token.email_verified === true && !newData.exists()))"
        }
      }
    },

    "gameHistory": {
      ".read": "auth != null && auth.token.email != null && auth.token.email_verified === true",
      "$gameId": {
        ".write": "auth != null && !data.exists() && root.child('rooms').child(newData.child('roomCode').val()).child('hostedByAdmin').val() === true",
        ".validate": "newData.hasChildren(['roomCode', 'completedAt', 'result'])"
      }
    }
  }
}
